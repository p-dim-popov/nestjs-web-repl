  "description": "Expose a live NestJS REPL over the network (HTTP + SSE + Monaco UI).",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/p-dim-popov/nestjs-web-repl.git"
  },
  "bugs": {
    "url": "https://github.com/p-dim-popov/nestjs-web-repl/issues"
  },
  "homepage": "https://github.com/p-dim-popov/nestjs-web-repl#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "example": "ts-node -T example/main.ts"
  },
  "peerDependencies": {
    "@nestjs/common": "^10 || ^11",
    "@nestjs/core": "^10 || ^11",
    "rxjs": "^7"
  },
  "devDependencies": {
    "@nestjs/common": "^11",
    "@nestjs/core": "^11",
    "@nestjs/platform-express": "^11",
    "@nestjs/testing": "^11",
    "@swc/core": "^1.15.43",
    "@types/node": "^20",
    "@types/supertest": "^6",
    "reflect-metadata": "^0.2",
    "rxjs": "^7",
    "supertest": "^7",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "unplugin-swc": "^1.5.9",
    "vitest": "^2"
  }
